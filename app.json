{
  "expo": {
    "name": "orientation-lock-repro",
    "slug": "orientation-lock-repro",
    "version": "1.0.0",
    "scheme": "orientation-lock-repro",
    "platforms": ["ios", "android"],
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.repro.orientationlock",
      "supportsTablet": true,
      "requireFullScreen": true
    },
    "android": {
      "package": "com.repro.orientationlock"
    },
    "orientation": "default",
    "plugins": [
      "expo-router",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "DEFAULT"
        }
      ]
    ]
  }
}
